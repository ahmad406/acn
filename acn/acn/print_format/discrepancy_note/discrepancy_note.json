 "font_size": 14,
 "html": "<style>\n    .dn-print {\n        font-family: Arial, sans-serif;\n        color: #000;\n        font-size: 12px;\n    }\n\n    .dn-body {\n        border: 2px solid #000;\n        margin-top:6px;\n    }\n\n    .dn-title {\n        text-align: center;\n        font-size: 22px;\n        font-weight: 700;\n        padding: 12px 0;\n        border-bottom: 1px solid #000;\n        letter-spacing: 1px;\n    }\n\n    .header-table,\n    .item-table {\n        width: 100%;\n        border-collapse: collapse;\n    }\n\n    .header-table td {\n        vertical-align: top;\n        padding: 10px;\n        border-bottom: 1px solid #000;\n    }\n\n    .address-box {\n        width: 55%;\n        border-right: 1px solid #000;\n        padding: 14px !important;\n        vertical-align: top;\n    }\n\n    .info-box {\n        width: 45%;\n        font-size: 14px;\n        padding: 18px !important;\n        vertical-align: top;\n    }\n\n    .label {\n        font-weight: 700;\n        font-size: 16px;\n    }\n\n    .item-table th,\n    .item-table td {\n        border: 1px solid #000;\n        padding: 6px 5px;\n        font-size: 11px;\n        vertical-align: top;\n    }\n\n    .item-table th {\n        text-align: center;\n        font-weight: 700;\n    }\n\n    .text-center {\n        text-align: center;\n    }\n\n    .notes {\n        padding: 14px;\n        border-top: 1px solid #000;\n        font-size: 12px;\n        line-height: 1.8;\n        min-height: 220px;\n    }\n\n    .notes-title {\n        font-weight: bold;\n        text-decoration: underline;\n        margin-bottom: 8px;\n    }\n\n    .signature {\n        text-align: right;\n        margin-top: 60px;\n        font-weight: bold;\n    }\n\n    .letter-head img {\n        max-width: 100%;\n    }\n\n    .letterhead-row {\n        margin-bottom: -1px;\n    }\n</style>\n{% set delivery_note = frappe.db.sql(\"\"\"\n    SELECT\n        dn.name,\n        dn.posting_date,\n        dn.address_display\n    FROM `tabDelivery Note` dn\n    INNER JOIN `tabDelivery Note Item` dni\n        ON dni.parent = dn.name\n    WHERE\n        dn.discrepancy_note = 1\n        AND dni.customer_dc_id = %s\n    LIMIT 1\n\"\"\", (doc.name,), as_dict=1) %}\n\n{% set dn = delivery_note[0] if delivery_note else None %}\n\n\n<div class=\"dn-print\">\n\n    <!-- LETTER HEAD -->\n    <div class=\"letterhead-row\">\n        {% if letter_head and not no_letterhead %}\n            <div class=\"letter-head\">\n                {{ letter_head }}\n            </div>\n        {% endif %}\n    </div>\n\n    {% if dn %}\n\n    <div class=\"dn-body\">\n\n        <!-- TITLE -->\n        <div class=\"dn-title\">\n            DISCERPENCY NOTE\n        </div>\n\n        <!-- HEADER -->\n        <table class=\"header-table\">\n            <tr>\n\n                <td class=\"address-box\">\n\n                    <div style=\"font-size:16px; font-weight:700; margin-bottom:8px;\">\n                        To,\n                    </div>\n\n                    <div style=\"line-height:1.5; font-size:13px;\">\n                        {{ doc.customer or \"\"}}\n                        <br>\n                        {{ dn.address_display or \"\" }}\n                    </div>\n\n                </td>\n\n                <td class=\"info-box\">\n\n                    <div style=\"margin-bottom:18px;\">\n                        <span class=\"label\">Discerpency No. :</span>\n                        {{ doc.name or \"\" }}\n                    </div>\n\n                    <div>\n                        <span class=\"label\">Date :</span>\n                        {{ frappe.utils.formatdate(doc.tran_date) if doc.tran_date else \"\" }}\n                    </div>\n\n                </td>\n\n            </tr>\n        </table>\n\n        <!-- ITEMS -->\n        <table class=\"item-table\">\n\n            <thead>\n                <tr>\n                    <th style=\"width:5%;\">Sl No.</th>\n                    <th style=\"width:12%;\">DC NO</th>\n                    <th style=\"width:12%;\">PART NO</th>\n                    <th style=\"width:33%;\">ITEM DESCRIPTION</th>\n                    <th style=\"width:10%;\">HSN Code</th>\n                    <th style=\"width:8%;\">QTY NOS</th>\n                    <th style=\"width:8%;\">QTY KGS</th>\n                    <th style=\"width:14%;\">DISCREPANCY FOUND</th>\n                    <th style=\"width:14%;\">REMARKS</th>\n                </tr>\n            </thead>\n\n            <tbody>\n\n                {% for row in doc.items %}\n\n                <tr>\n\n                    <td class=\"text-center\">\n                        {{ loop.index }}\n                    </td>\n\n\n                    <td class=\"text-center\">\n                        {{ row.customer_dc_no }}\n                    </td>\n\n                    <td class=\"text-center\">\n                        {{ row.part_no or \"\" }}\n                    </td>\n\n                    <td>\n                        {{ row.item_name or \"\" }}\n                    </td>\n\n                    <td class=\"text-center\">\n                        {{ row.eway_bill_hsn or \"\" }}\n                    </td>\n\n                    <td class=\"text-center\">\n                        {{ row.qty_not_ok_for_process_nos or \"\" }}\n                    </td>\n\n                    <td class=\"text-center\">\n                        {{ row.qty_not_ok_for_process_kgs or \"\" }}\n                    </td>\n\n                    <td>\n                        {{ row.discrepancy_reasons }}\n                    </td>\n                    \n                    <td>\n                        {{ row.remarks }}\n                    </td>\n\n                </tr>\n\n                {% endfor %}\n\n            </tbody>\n\n        </table>\n\n        <!-- NOTES -->\n        <div class=\"notes\">\n\n            <div class=\"notes-title\">\n                NOTE :\n            </div>\n\n            <div>\n                We kindly request that you investigate this matter and advise us on the next steps to resolve this issue.\n            </div>\n\n            <div>\n                We have temporarily withheld your material from further processing till the issue is resolved.\n            </div>\n\n            <div style=\"margin-top:24px;\">\n                Contact for any clarification on the above :\n                <b>9036070084 / 9035052577</b>\n            </div>\n\n            <div class=\"signature\">\n\n                <div>\n                    for ACE CARBO NITRIDERS\n                </div>\n\n                <div style=\"margin-top:60px;\">\n                    AUTHORISED SIGNATORY\n                </div>\n\n            </div>\n\n        </div>\n\n    </div>\n\n    {% else %}\n\n    <div style=\"\n        text-align:center;\n        margin-top:80px;\n        font-size:22px;\n        font-weight:700;\n    \">\n        No Discrepancy Note created for this Customer DC.\n    </div>\n\n    {% endif %}\n\n</div>",
