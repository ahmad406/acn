 "doc_type": "Proforma Invoice",
 "docstatus": 0,
 "doctype": "Print Format",
 "font_size": 14,
 "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <style>\n        body { font-family: Arial, sans-serif; font-size: 11px; margin: 0; padding: 20px; }\n        \n        .invoice-title { \n            text-align: center; font-weight: bold; font-size: 15px; \n            margin: 10px 0 15px 0; text-decoration: underline; letter-spacing: 1px;\n        }\n        \n        .header-table { width: 100%; border-collapse: collapse; margin-bottom: 12px; }\n        .header-table td { border: 1px solid #000; padding: 8px 10px; vertical-align: top; }\n        \n        .items-table { width: 100%; border-collapse: collapse; }\n        .items-table th { \n            background-color: #e8e8e8; border: 1px solid #000; \n            padding: 5px 4px; text-align: center; font-size: 10px;\n        }\n        .items-table td { \n            border: 1px solid #000; padding: 4px 5px; \n            text-align: center; font-size: 11px;\n        }\n        .items-table td.left { text-align: left; }\n        .items-table td.right { text-align: right; }\n\n        .bottom-table { width: 100%; border-collapse: collapse; border-top: none; }\n        .bottom-table > tbody > tr > td { \n            border: 1px solid #000; vertical-align: top; padding: 0; \n        }\n\n        .totals-table { width: 100%; border-collapse: collapse; }\n        .totals-table td { \n            padding: 5px 10px; \n            border-bottom: 1px solid #eee; \n            font-size: 11px; \n        }\n        .totals-table td:first-child { text-align: right; font-weight: bold; width: 68%; }\n        .totals-table td:last-child { text-align: right; }\n        .totals-table tr.subtotal-row td { border-top: 1px solid #aaa; }\n        .totals-table tr.total-row td { \n            border-top: 2px solid #000; \n            border-bottom: 2px solid #000;\n            font-weight: bold; \n            font-size: 12px;\n            background-color: #f5f5f5;\n        }\n\n        .notes-box { \n            border: 1px solid #000; \n            padding: 8px 10px; \n            margin-top: 0px;\n            font-size: 10px; \n            line-height: 1.6;\n            white-space: pre-wrap;\n        }\n        .footer { \n            display: flex; justify-content: space-between; \n            margin-top: 30px; padding: 0 10px; \n        }\n    </style>\n</head>\n<body>\n\n{% if letter_head and not no_letterhead %}\n<div class=\"letter-head\">{{ letter_head }}</div>\n{% endif %}\n\n<!-- Title -->\n<div class=\"invoice-title\">PROFORMA INVOICE</div>\n\n<!-- Header -->\n<table class=\"header-table\">\n    <tr>\n        <td style=\"width:50%\">\n            <strong>To,</strong><br>\n            <strong>{{ frappe.db.get_value(\"Customer DC\", doc.customer_dc_id, \"customer\") or \"\" }}</strong><br>\n            {{ doc.address or \"\" }}\n        </td>\n        <td style=\"width:50%\">\n            <strong>Proforma Invoice No. :</strong> {{ doc.name }}<br>\n            <strong>Proforma Invoice Date :</strong> \n    {{ frappe.utils.formatdate(doc.proforma_invoice_date, \"dd-MM-yyyy\") }}<br>\n            {% if doc.customer_dc_id %}\n            <strong>Our MRN No. :</strong> {{ doc.customer_dc_id }}<br>\n            {% endif %}\n            {% if doc.sales_order_no %}\n            <strong>Customer Order No. :</strong> {{ doc.customer_order_no }}<br>\n            {% endif %}\n            {% if doc.customer_dc_id %}\n           <strong>Customer Order Date :</strong> \n    {{ frappe.utils.formatdate(doc.customer_order_date, \"dd-MM-yyyy\") }}<br>\n            {% endif %}\n            {% if doc.sales_order_no %}\n            <strong>Customer DC No. :</strong> {{ doc.customer_dc_no }}<br>\n            {% endif %}\n            {% if doc.customer_dc_id %}\n            <strong>Customer DC Date :</strong> \n    {{ frappe.utils.formatdate(doc.customer_dc_date, \"dd-MM-yyyy\") }}<br>\n            {% endif %}\n            \n        </td>\n    </tr>\n</table>\n\n<!-- Items Table -->\n<table class=\"items-table\">\n    <thead>\n        <tr>\n            <th rowspan=\"2\" style=\"width:4%\">Sl.<br>No.</th>\n            <th rowspan=\"2\" style=\"width:9%\">Part No.</th>\n            <th rowspan=\"2\" style=\"width:12%\">Process</th>\n            <th rowspan=\"2\" style=\"width:20%; text-align:left; padding-left:6px;\">Item Description</th>\n            <th rowspan=\"2\" style=\"width:8%\">HSN Code /<br>SAC Code</th>\n            <th colspan=\"2\">QNTY</th>\n            <th rowspan=\"2\" style=\"width:7%\">UOM</th>\n            <th rowspan=\"2\" style=\"width:8%\">RATE</th>\n            <th colspan=\"2\">AMOUNT</th>\n        </tr>\n        <tr>\n            <th style=\"width:6%\">NOS</th>\n            <th style=\"width:6%\">KGS</th>\n            <th style=\"width:6%\">Rs.</th>\n            <th style=\"width:6%\">Ps.</th>\n        </tr>\n    </thead>\n    <tbody>\n        {% for row in doc.proforma_invoice_table %}\n        <tr>\n            <td>{{ row.idx }}</td>\n            <td>{{ row.part_no or \"\" }}</td>\n            <td>\n                {{ row.process_name or \"\" }}\n                {% if row.process_type %}<br><small style=\"color:#555;\">{{ row.process_type }}</small>{% endif %}\n            </td>\n            <td class=\"left\" style=\"padding-left:6px;\">\n                {{ row.item_description or row.item_name or \"\" }}\n                {% if row.material %}<br><small style=\"color:#666;\">{{ row.material }}</small>{% endif %}\n            </td>\n            <td>{{ row.hsn_code__sac_code or \"\" }}</td>\n            <td>{{ row.qty_nos if row.qty_nos else \"\" }}</td>\n            <td>{{ row.qty_kgs if row.qty_kgs else \"\" }}</td>\n            <td>{{ row.uom or \"\" }}</td>\n            <td class=\"right\">{% if row.rate %}{{ \"%.2f\"|format(row.rate) }}{% endif %}</td>\n            <td class=\"right\">{% if row.amount %}{{ (row.amount)|int }}{% endif %}</td>\n            <td class=\"right\">\n                {% if row.amount %}{{ \"%.0f\"|format(((row.amount) - (row.amount)|int) * 100) }}{% endif %}\n            </td>\n        </tr>\n        {% endfor %}\n    </tbody>\n</table>\n\n<!-- Bottom: Words + Totals -->\n<table class=\"bottom-table\">\n    <tr>\n        <td style=\"width:40%; padding: 5px 8px; vertical-align:top; font-size:9px;\">\n    <strong>TOTAL INVOICE VALUE IN WORDS : </strong><em>{{ doc.in_words or \"\" }}</em>\n</td>\n        <td style=\"width:58%; padding:0; vertical-align:top;\">\n            <table class=\"totals-table\">\n\n                {% for tax in doc.taxes_and_charges %}\n                <tr>\n                    <td>{{ tax.description or tax.account_head }} @ {{ tax.rate }}% :</td>\n                    <td>{{ tax.get_formatted('tax_amount') }}</td>\n                </tr>\n                {% endfor %}\n\n                <tr class=\"subtotal-row\">\n                    <td>TOTAL TAXES &amp; CHARGES :</td>\n                    <td>\n                        {% if doc.total_taxes_and_charges %}\n                            {{ doc.get_formatted('total_taxes_and_charges') }}\n                        {% else %}-{% endif %}\n                    </td>\n                </tr>\n\n                <tr class=\"total-row\">\n                    <td>GRAND TOTAL :</td>\n                    <td>{{ doc.get_formatted('grand_total') }}</td>\n                </tr>\n\n            </table>\n        </td>\n    </tr>\n</table>\n\n<!-- Notes -->\n<div class=\"notes-box\"><strong>NOTE :</strong>\n{{ doc.note or \"\" }}</div>\n\n<!-- Footer -->\n<div class=\"footer\">\n    <div style=\"text-align:right;\">\n        <strong>for ACE CARBO NITRIDERS</strong><br><br>\n        <strong>AUTHORISED SIGNATORY</strong>\n    </div>\n</div>\n\n</body>\n</html>",
