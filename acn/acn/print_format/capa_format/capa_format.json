 "font_size": 14,
 "html": "<style>\r\n    * {\r\n        box-sizing: border-box;\r\n        margin: 0;\r\n        padding: 0;\r\n    }\r\n\r\n    body {\r\n        font-family: Arial, sans-serif;\r\n        font-size: 11px;\r\n    }\r\n\r\n    .capa-table {\r\n        width: 100%;\r\n        border-collapse: collapse;\r\n        font-size: 11px;\r\n        font-family: Arial, sans-serif;\r\n    }\r\n\r\n    .capa-table td,\r\n    .capa-table th {\r\n        border: 1px solid #000;\r\n        padding: 5px 6px;\r\n        vertical-align: top;\r\n    }\r\n\r\n    .center { text-align: center; }\r\n    .bold { font-weight: bold; }\r\n\r\n    /* Header title cell */\r\n    .header-title {\r\n        text-align: center;\r\n        vertical-align: middle;\r\n    }\r\n    .header-title .main-title {\r\n        font-size: 14px;\r\n        font-weight: bold;\r\n        letter-spacing: 0.5px;\r\n    }\r\n    .header-title .sub-title {\r\n        font-size: 11px;\r\n        font-weight: bold;\r\n    }\r\n\r\n    /* Rec/Rev box */\r\n    .rec-box {\r\n        font-size: 10px;\r\n        vertical-align: top;\r\n        white-space: nowrap;\r\n    }\r\n    .rec-box table {\r\n        border-collapse: collapse;\r\n        width: 100%;\r\n    }\r\n    .rec-box table td {\r\n        border: 1px solid #000;\r\n        padding: 2px 4px;\r\n        font-size: 10px;\r\n    }\r\n\r\n    /* Section title rows */\r\n    .section-title {\r\n        background: #d9d9d9;\r\n        font-weight: bold;\r\n        font-size: 11px;\r\n        padding: 4px 6px;\r\n    }\r\n\r\n    /* Root cause row with big R badges */\r\n    .root-cause-row {\r\n        background: #d9d9d9;\r\n        font-weight: bold;\r\n    }\r\n    .rc-badge {\r\n        display: inline-block;\r\n        font-size: 18px;\r\n        font-weight: 900;\r\n        color: #000;\r\n        margin: 0 2px;\r\n        vertical-align: middle;\r\n        line-height: 1;\r\n    }\r\n    .rc-label {\r\n        font-size: 11px;\r\n        font-weight: bold;\r\n        vertical-align: middle;\r\n    }\r\n    .rc-filled {\r\n        display: inline-block;\r\n        background: #333;\r\n        color: #fff;\r\n        font-size: 11px;\r\n        font-weight: bold;\r\n        padding: 1px 6px;\r\n        vertical-align: middle;\r\n        margin-left: 4px;\r\n    }\r\n\r\n    /* Images side by side */\r\n    .img-row {\r\n        display: flex;\r\n        gap: 20px;\r\n        justify-content: center;\r\n        padding: 8px 0;\r\n    }\r\n    .img-cell {\r\n        text-align: center;\r\n    }\r\n    .img-cell img {\r\n        width: 220px;\r\n        height: 160px;\r\n        object-fit: cover;\r\n        border: 1px solid #000;\r\n        display: block;\r\n        margin: 0 auto 4px auto;\r\n    }\r\n    .img-caption {\r\n        font-size: 9px;\r\n        text-align: center;\r\n        max-width: 220px;\r\n    }\r\n\r\n    /* Corrective action list */\r\n    .ca-list {\r\n        padding: 4px 6px;\r\n    }\r\n    .ca-item {\r\n        margin-bottom: 6px;\r\n    }\r\n\r\n    /* Problem solving team */\r\n    .team-table {\r\n        width: 100%;\r\n        border-collapse: collapse;\r\n    }\r\n    .team-table td {\r\n        border: 1px solid #000;\r\n        padding: 4px 8px;\r\n        vertical-align: top;\r\n        width: 33.33%;\r\n    }\r\n    .team-header {\r\n        text-align: center;\r\n        font-weight: bold;\r\n        font-size: 11px;\r\n    }\r\n    .sig-row td {\r\n        height: 30px;\r\n        vertical-align: bottom;\r\n        font-size: 10px;\r\n    }\r\n\r\n    /* Nature of complaint \u2014 larger text like screenshot */\r\n    .nature-text {\r\n        font-size: 13px;\r\n        font-weight: bold;\r\n        padding: 4px 6px;\r\n    }\r\n\r\n    .no-border-inner td {\r\n        border: none !important;\r\n    }\r\n</style>\r\n\r\n<table class=\"capa-table\">\r\n\r\n    <!-- LETTERHEAD + HEADER -->\r\n    <tr>\r\n        <td colspan=\"2\" style=\"border:1px solid #000; padding:0;\" width=\"75%\">\r\n            <!-- Letterhead goes here -->\r\n            <div>\r\n                {% if letter_head and not no_letterhead %}\r\n                    <div class=\"letter-head\" style=\"margin-top: -5px\">{{ letter_head }}</div>\r\n                {% endif %}\r\n            </div>\r\n        </td>\r\n        <!-- Rec/Rev/Date box top-right -->\r\n        <td class=\"rec-box\" width=\"25%\" style=\"border:1px solid #000; vertical-align:top;\">\r\n            <table>\r\n                <tr>\r\n                    <td><b>Rec No</b></td>\r\n                    <td>{{ doc.name }}</td>\r\n                </tr>\r\n                <tr>\r\n                    <td><b>Rev No</b></td>\r\n                    <td>0</td>\r\n                </tr>\r\n                <tr>\r\n                    <td><b>Rev Date</b></td>\r\n                    <td>{{ frappe.utils.formatdate(doc.transaction_date) }}</td>\r\n                </tr>\r\n            </table>\r\n        </td>\r\n    </tr>\r\n\r\n    <!-- Title row (separate from letterhead so it appears below) -->\r\n    <tr>\r\n        <td colspan=\"3\" class=\"header-title\" style=\"border:1px solid #000; padding: 6px;\">\r\n            <div class=\"main-title\">CORRECTIVE-PREVENTIVE ACTION REPORT</div>\r\n            <div class=\"sub-title\">FOR CUSTOMER COMPLAINTS</div>\r\n        </td>\r\n    </tr>\r\n\r\n    <!-- BASIC DETAILS \u2014 2 columns, 5 rows + Nature of Complaint full width -->\r\n    <tr>\r\n        <td width=\"50%\"><b>Customer :</b> {{ doc.customer or \"\" }}</td>\r\n        <td width=\"50%\" colspan=\"2\"><b>CPA No :</b> </td>\r\n    </tr>\r\n\r\n    <tr>\r\n        <td><b>Part Name :</b> {{ doc.item_name or \"\" }}</td>\r\n        <td colspan=\"2\"><b>Customer's Ref :</b> {{ doc.customer_complaint_id or \"\" }}</td>\r\n    </tr>\r\n\r\n    <tr>\r\n        <td><b>Drg. No. :</b> </td>\r\n        <td colspan=\"2\"><b>Date :</b> {{ frappe.utils.formatdate(doc.transaction_date) }}</td>\r\n    </tr>\r\n\r\n    <tr>\r\n        <td><b>Invoice No :</b> {{ doc.invoice_no or \"\" }}</td>\r\n        <td colspan=\"2\"><b>Total Qty :</b> {{ doc.total_qty_nos or 0 }} Nos</td>\r\n    </tr>\r\n\r\n    <tr>\r\n        <td><b>Process :</b> {{ doc.process_type or \"\" }}</td>\r\n        <td colspan=\"2\"><b>Defective Qty :</b> {{ doc.defective_qty_nos or 0 }} Nos</td>\r\n    </tr>\r\n\r\n    <!-- Nature of Complaint \u2014 full width below -->\r\n    <tr>\r\n        <td colspan=\"3\"><b>Nature of Complaint :</b>&nbsp;&nbsp;<span style=\"font-size:13px; font-weight:bold;\">{{ doc.nature_of_complaint or \"\" }}</span></td>\r\n    </tr>\r\n\r\n    <!-- IMMEDIATE ACTION -->\r\n    <tr>\r\n        <td colspan=\"3\" class=\"section-title\">Immediate Containment Actions :-</td>\r\n    </tr>\r\n    <tr>\r\n        <td colspan=\"3\" style=\"padding: 5px 6px; white-space: pre-wrap;\">{{ doc.immediate_containment_action or \"\" }}</td>\r\n    </tr>\r\n\r\n    <!-- ROOT CAUSE -->\r\n    <tr>\r\n        <td colspan=\"3\" class=\"root-cause-row\" style=\"padding: 4px 6px; border:1px solid #000;\">\r\n            <span  style=\"font-size:14px;\" class=\"rc-label\">Root Cause :-</span>\r\n            &nbsp;&nbsp;&nbsp;\r\n            <span class=\"rc-label\">PROCESS FAILURE</span>\r\n            &nbsp;\r\n            {% if doc.process_failure %}\r\n                <span style=\"font-size:16px; vertical-align:middle;\">&#10004;</span>\r\n            {% else %}\r\n                <span style=\"font-size:16px; vertical-align:middle;\">&#10008;</span>\r\n            {% endif %}\r\n            &nbsp;\r\n            <span class=\"rc-label\">DETECTION FAILURE</span>\r\n            &nbsp;\r\n            {% if doc.detection_failure %}\r\n                <span style=\"font-size:16px; vertical-align:middle;\">&#10004;</span>\r\n            {% else %}\r\n                <span style=\"font-size:16px; vertical-align:middle;\">&#10008;</span>\r\n            {% endif %}\r\n            &nbsp;\r\n            <span class=\"rc-label\">SYSTEM FAILURE</span>\r\n            &nbsp;;\r\n            {% if doc.system_failure %}\r\n                <span style=\"font-size:16px; vertical-align:middle;\">&#10004;</span>\r\n            {% else %}\r\n                <span style=\"font-size:16px; vertical-align:middle;\">&#10008;</span>\r\n            {% endif %}\r\n            &nbsp;\r\n        </td>\r\n    </tr>\r\n\r\n    <!-- ROOT CAUSE DETAIL -->\r\n    <tr>\r\n        <td colspan=\"3\" style=\"padding: 6px; white-space: pre-wrap; line-height: 1.5;\">{{ doc.root_cause_description or \"\" }}</td>\r\n    </tr>\r\n\r\n    <!-- IMAGES (case + core side by side) -->\r\n    {% if doc.microstructure_case or doc.microstructure_core %}\r\n    <tr>\r\n        <td colspan=\"3\" style=\"border:1px solid #000; padding: 8px;\">\r\n            <div class=\"img-row\">\r\n                {% if doc.microstructure_case %}\r\n                <div class=\"img-cell\">\r\n                    <img src=\"{{ doc.microstructure_case }}\">\r\n                    <div class=\"img-caption\">Microstructure Case : White Layer 15-17\u00b5 with Network Needles</div>\r\n                </div>\r\n                {% endif %}\r\n                {% if doc.microstructure_core %}\r\n                <div class=\"img-cell\">\r\n                    <img src=\"{{ doc.microstructure_core }}\">\r\n                    <div class=\"img-caption\">Microstructure Case : White Layer 8-11\u00b5 with Nitriding Needles</div>\r\n                </div>\r\n                {% endif %}\r\n            </div>\r\n        </td>\r\n    </tr>\r\n    {% endif %}\r\n\r\n    <!-- CORRECTIVE ACTION -->\r\n    <tr>\r\n        <td colspan=\"3\" class=\"section-title\">Corrective Action:-</td>\r\n    </tr>\r\n    <tr>\r\n        <td colspan=\"3\" style=\"padding:0;\">\r\n            <table style=\"width:100%; border-collapse:collapse; font-size:11px;\">\r\n                <thead>\r\n                    <tr style=\"background:#f2f2f2;\">\r\n                        <th style=\"border:1px solid #000; padding:4px 6px; width:40px; text-align:center;\">No.</th>\r\n                        <th style=\"border:1px solid #000; padding:4px 6px; text-align:left;\">Corrective Action Note</th>\r\n                        <th style=\"border:1px solid #000; padding:4px 6px; width:180px; text-align:left;\">Action Responsible</th>\r\n                    </tr>\r\n                </thead>\r\n                <tbody>\r\n                    {% for row in doc.corrective_action %}\r\n                    <tr>\r\n                        <td style=\"border:1px solid #000; padding:4px 6px; text-align:center;\">{{ loop.index }}</td>\r\n                        <td style=\"border:1px solid #000; padding:4px 6px;\">{{ row.corrective_action_note or \"\" }}</td>\r\n                        <td style=\"border:1px solid #000; padding:4px 6px;\">{{ row.action_responsible or \"\" }}</td>\r\n                    </tr>\r\n                    {% endfor %}\r\n                </tbody>\r\n            </table>\r\n        </td>\r\n    </tr>\r\n\r\n    <!-- PROBLEM SOLVING TEAM -->\r\n    <tr>\r\n        <td colspan=\"3\" class=\"section-title\">Problem Solving Team</td>\r\n    </tr>\r\n    <tr>\r\n        <td colspan=\"3\" style=\"padding:0;\">\r\n            <table style=\"width:100%; border-collapse:collapse; font-size:11px;\">\r\n                <thead>\r\n                    <tr style=\"background:#f2f2f2;\">\r\n                        <th style=\"border:1px solid #000; padding:4px 6px; width:40px; text-align:center;\">No.</th>\r\n                        <th style=\"border:1px solid #000; padding:4px 6px; text-align:left;\">Employee</th>\r\n                        <th style=\"border:1px solid #000; padding:4px 6px; width:180px; text-align:left;\">Designation</th>\r\n                    </tr>\r\n                </thead>\r\n                <tbody>\r\n                    {% for row in doc.problem_solving_team %}\r\n                    <tr>\r\n                        <td style=\"border:1px solid #000; padding:4px 6px; text-align:center;\">{{ loop.index }}</td>\r\n                        <td style=\"border:1px solid #000; padding:4px 6px;\">{{ row.employee or \"\" }}</td>\r\n                        <td style=\"border:1px solid #000; padding:4px 6px;\">{{ row.designation or \"\" }}</td>\r\n                    </tr>\r\n                    {% endfor %}\r\n                </tbody>\r\n            </table>\r\n        </td>\r\n    </tr>\r\n\r\n</table>",
