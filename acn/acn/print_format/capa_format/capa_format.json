 "font_size": 14,
 "html": "<style>\n    .capa-table {\n        width: 100%;\n        border-collapse: collapse;\n        font-size: 11px;\n        font-family: Arial, sans-serif;\n    }\n\n    .capa-table td,\n    .capa-table th {\n        border: 1px solid #000;\n        padding: 4px;\n        vertical-align: top;\n    }\n\n    .center {\n        text-align: center;\n    }\n\n    .bold {\n        font-weight: bold;\n    }\n\n    .heading {\n        font-size: 18px;\n        font-weight: bold;\n    }\n\n    .sub-heading {\n        font-size: 13px;\n        font-weight: bold;\n    }\n\n    .checkbox {\n        font-size: 16px;\n        font-weight: bold;\n    }\n\n    .section-title {\n        background: #efefef;\n        font-weight: bold;\n    }\n\n    .img-box {\n        text-align: center;\n        padding: 10px;\n    }\n\n    .img-box img {\n        width: 250px;\n        height: auto;\n        border: 1px solid #000;\n    }\n\n    .small-text {\n        font-size: 10px;\n    }\n</style>\n\n<table class=\"capa-table\">\n\n    <!-- HEADER -->\n    <tr>\n        <td rowspan=\"3\" width=\"20%\" class=\"center\">\n            <img src=\"/files/acn_logo.png\" style=\"max-width:120px;\">\n        </td>\n\n        <td colspan=\"2\" class=\"center\">\n            <div class=\"heading\">Ace Carbo Nitriders</div>\n            <div class=\"sub-heading\">\n                CORRECTIVE-PREVENTIVE ACTION REPORT<br>\n                FOR CUSTOMER COMPLAINTS\n            </div>\n        </td>\n\n        <td width=\"15%\">\n            <b>Rec No</b><br>\n            {{ doc.name }}\n        </td>\n    </tr>\n\n    <tr>\n        <td colspan=\"2\"></td>\n\n        <td>\n            <b>Rev No</b><br>\n            0\n        </td>\n    </tr>\n\n    <tr>\n        <td colspan=\"2\"></td>\n\n        <td>\n            <b>Rev Date</b><br>\n            {{ frappe.utils.formatdate(doc.transaction_date) }}\n        </td>\n    </tr>\n\n    <!-- BASIC DETAILS -->\n\n    <tr>\n        <td><b>Customer :</b> {{ doc.customer or \"\" }}</td>\n        <td><b>CPA No :</b> {{ doc.name }}</td>\n        <td colspan=\"2\">\n            <b>Customer's Ref :</b> {{ doc.customer_complaint_id or \"\" }}\n        </td>\n    </tr>\n\n    <tr>\n        <td><b>Part Name :</b> {{ doc.item_name or \"\" }}</td>\n        <td><b>Drg. No. :</b> {{ doc.item_code or \"\" }}</td>\n        <td colspan=\"2\">\n            <b>Date :</b> {{ frappe.utils.formatdate(doc.transaction_date) }}\n        </td>\n    </tr>\n\n    <tr>\n        <td>\n            <b>Invoice No :</b> {{ doc.invoice_no or \"\" }}\n        </td>\n\n        <td>\n            <b>Total Qty :</b>\n            {{ doc.total_qty_nos or 0 }} Nos\n        </td>\n\n        <td colspan=\"2\">\n            <b>Defective Qty :</b>\n            {{ doc.defective_qty_nos or 0 }} Nos\n        </td>\n    </tr>\n\n    <tr>\n        <td>\n            <b>Process :</b> {{ doc.process_type or \"\" }}\n        </td>\n\n        <td colspan=\"3\">\n            <b>Nature of Complaint :</b>\n            {{ doc.nature_of_complaint or \"\" }}\n        </td>\n    </tr>\n\n    <!-- IMMEDIATE ACTION -->\n\n    <tr>\n        <td colspan=\"4\" class=\"section-title\">\n            Immediate Containment Actions :\n        </td>\n    </tr>\n\n    <tr>\n        <td colspan=\"4\">\n            {{ doc.immediate_containment_action or \"\" }}\n        </td>\n    </tr>\n\n    <!-- ROOT CAUSE -->\n\n    <tr>\n        <td colspan=\"4\" class=\"section-title\">\n            Root Cause\n\n            &nbsp;&nbsp;&nbsp;\n\n            {% if doc.root_cause %}\n                \u2611\n            {% else %}\n                \u2610\n            {% endif %}\n            PROCESS FAILURE\n\n            &nbsp;&nbsp;&nbsp;\n\n            {% if doc.detection_failure %}\n                \u2611\n            {% else %}\n                \u2610\n            {% endif %}\n            DETECTION FAILURE\n\n            &nbsp;&nbsp;&nbsp;\n\n            {% if doc.system_failure %}\n                \u2611\n            {% else %}\n                \u2610\n            {% endif %}\n            SYSTEM FAILURE\n        </td>\n    </tr>\n\n    <tr>\n        <td colspan=\"4\">\n            {{ doc.detailed_report or \"\" }}\n        </td>\n    </tr>\n\n    <!-- IMAGE -->\n\n    {% if doc.microstructure_case %}\n    <tr>\n        <td colspan=\"4\" class=\"img-box\">\n            <img src=\"{{ doc.microstructure_case }}\">\n        </td>\n    </tr>\n    {% endif %}\n\n    <!-- CORRECTIVE ACTION -->\n\n    <tr>\n        <td colspan=\"4\" class=\"section-title\">\n            Corrective Action :\n        </td>\n    </tr>\n\n    <tr>\n        <td colspan=\"4\">\n\n            <table style=\"width:100%; border-collapse: collapse;\">\n                <tr>\n                    <th style=\"border:1px solid #000;\">Sr.</th>\n                    <th style=\"border:1px solid #000;\">Action</th>\n                </tr>\n\n                {% for row in doc.corrective_action %}\n                <tr>\n                    <td style=\"border:1px solid #000; width:50px;\">\n                        {{ loop.index }}\n                    </td>\n\n                    <td style=\"border:1px solid #000;\">\n                        {{ row.corrective_action or \"\" }}\n                    </td>\n                </tr>\n                {% endfor %}\n            </table>\n\n        </td>\n    </tr>\n\n    <!-- TEAM -->\n\n    <tr>\n        <td colspan=\"4\" class=\"section-title center\">\n            Problem Solving Team\n        </td>\n    </tr>\n\n    <tr>\n        {% for row in doc.problem_solving_team %}\n            <td class=\"center\">\n                <b>{{ row.employee_name or \"\" }}</b><br><br>\n                Signature\n            </td>\n        {% endfor %}\n    </tr>\n\n</table>",
